{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code.v2.schema.json",
  "title": "Code Exchange v2",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[a-z0-9]+(?:-[a-z0-9]+)*_(dev|test|qa|prod)_[a-z0-9]{4}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "bounded_text": {
      "type": "string",
      "maxLength": 180
    }
  },
  "properties": {
    "protocol_version": {
      "const": "workflow.v2"
    },
    "from": {
      "enum": [
        "root_orchestrator",
        "code"
      ]
    },
    "to": {
      "enum": [
        "root_orchestrator",
        "code"
      ]
    },
    "type": {
      "enum": [
        "INIT_CODE",
        "CODE_PROGRESS",
        "FINAL_AUTHORING_EVIDENCE",
        "ERROR"
      ]
    },
    "run_id": {
      "$ref": "#/$defs/run_id"
    },
    "payload": {
      "type": "object"
    }
  },
  "required": [
    "protocol_version",
    "from",
    "to",
    "type",
    "run_id",
    "payload"
  ],
  "oneOf": [
    {
      "properties": {
        "from": {
          "const": "root_orchestrator"
        },
        "to": {
          "const": "code"
        },
        "type": {
          "const": "INIT_CODE"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requirements_artifact_path": {
              "type": "string",
              "minLength": 1
            },
            "research_evidence_artifact_path": {
              "type": "string",
              "minLength": 1
            },
            "service_confirmations_artifact_path": {
              "type": "string",
              "minLength": 1
            },
            "approval_markers": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "gate1_marker_path": {
                  "type": "string",
                  "minLength": 1
                },
                "gate2_marker_path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "gate1_marker_path",
                "gate2_marker_path"
              ]
            },
            "destination_path": {
              "type": "string",
              "minLength": 1
            },
            "mode": {
              "type": "string",
              "enum": [
                "full",
                "preflight",
                "remediation"
              ]
            },
            "validator_evidence_artifact_path": {
              "type": "string",
              "minLength": 1
            },
            "remediation_blockers": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "requirements_artifact_path",
            "research_evidence_artifact_path",
            "service_confirmations_artifact_path",
            "approval_markers",
            "destination_path"
          ]
        }
      }
    },
    {
      "properties": {
        "from": {
          "const": "code"
        },
        "to": {
          "const": "root_orchestrator"
        },
        "type": {
          "const": "CODE_PROGRESS"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "progress_message": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "progress_message"
          ]
        }
      }
    },
    {
      "properties": {
        "from": {
          "const": "code"
        },
        "to": {
          "const": "root_orchestrator"
        },
        "type": {
          "const": "FINAL_AUTHORING_EVIDENCE"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "artifact_path": {
              "type": "string",
              "minLength": 1
            },
            "artifact_sha256": {
              "$ref": "#/$defs/sha256"
            },
            "preview": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 600
                },
                "top_files_written": {
                  "type": "array",
                  "maxItems": 5,
                  "items": {
                    "$ref": "#/$defs/bounded_text"
                  }
                },
                "top_blockers": {
                  "type": "array",
                  "maxItems": 5,
                  "items": {
                    "$ref": "#/$defs/bounded_text"
                  }
                }
              },
              "required": [
                "summary",
                "top_files_written",
                "top_blockers"
              ]
            },
            "counts": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "files_written_total": {
                  "type": "integer",
                  "minimum": 0
                },
                "avm_modules_total": {
                  "type": "integer",
                  "minimum": 0
                },
                "blockers_total": {
                  "type": "integer",
                  "minimum": 0
                },
                "truncated": {
                  "type": "boolean"
                }
              },
              "required": [
                "files_written_total",
                "avm_modules_total",
                "blockers_total",
                "truncated"
              ]
            }
          },
          "required": [
            "artifact_path",
            "artifact_sha256",
            "preview",
            "counts"
          ]
        }
      }
    },
    {
      "properties": {
        "from": {
          "const": "code"
        },
        "to": {
          "const": "root_orchestrator"
        },
        "type": {
          "const": "ERROR"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "message": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "message"
          ]
        }
      }
    }
  ]
}