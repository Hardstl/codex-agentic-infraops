{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "authoring-evidence-artifact.v2.schema.json",
  "title": "Authoring Evidence Artifact v2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocol_version": {
      "const": "workflow.v2"
    },
    "artifact_type": {
      "const": "authoring.evidence.v2"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[a-z0-9]+(?:-[a-z0-9]+)*_(dev|test|qa|prod)_[a-z0-9]{4}$"
    },
    "generated_by": {
      "const": "code"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "present": {
                "type": "boolean"
              },
              "last_modified_utc": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": [
              "path",
              "present"
            ]
          }
        },
        "selected_service_options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "service": {
                "type": "string",
                "minLength": 1
              },
              "selected_option": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "service",
              "selected_option"
            ]
          }
        },
        "avm_modules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "resource_type": {
                "type": "string",
                "minLength": 1
              },
              "module_path": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "resource_type",
              "module_path",
              "version"
            ]
          }
        },
        "files_written": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bicep_diagnostics": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "passed",
                    "failed",
                    "skipped"
                  ]
                },
                "summary": {
                  "type": "string"
                }
              },
              "required": [
                "status",
                "summary"
              ]
            },
            "bicep_build": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "passed",
                    "failed",
                    "skipped"
                  ]
                },
                "summary": {
                  "type": "string"
                }
              },
              "required": [
                "status",
                "summary"
              ]
            },
            "bicep_lint": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "passed",
                    "failed",
                    "skipped"
                  ]
                },
                "summary": {
                  "type": "string"
                }
              },
              "required": [
                "status",
                "summary"
              ]
            }
          },
          "required": [
            "bicep_diagnostics",
            "bicep_build",
            "bicep_lint"
          ]
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "input_artifacts",
        "selected_service_options",
        "avm_modules",
        "files_written",
        "validations",
        "blockers",
        "notes"
      ]
    }
  },
  "required": [
    "protocol_version",
    "artifact_type",
    "run_id",
    "generated_by",
    "generated_at",
    "data"
  ]
}
