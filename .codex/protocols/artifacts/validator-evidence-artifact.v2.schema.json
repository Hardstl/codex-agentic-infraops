{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validator-evidence-artifact.v2.schema.json",
  "title": "Validator Evidence Artifact v2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocol_version": {
      "const": "workflow.v2"
    },
    "artifact_type": {
      "const": "validator.evidence.v2"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[a-z0-9]+(?:-[a-z0-9]+)*_(dev|test|qa|prod)_[a-z0-9]{4}$"
    },
    "generated_by": {
      "const": "validate"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validation_status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "check_summary": {
          "type": "string",
          "minLength": 1
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail",
                  "skip"
                ]
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "status",
              "evidence",
              "notes"
            ]
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validated_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "inputs_used": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rule_set_version": {
          "type": "string",
          "minLength": 1
        },
        "tool_results": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bicep_diagnostics": {
              "type": "string"
            },
            "bicep_build": {
              "type": "string"
            },
            "bicep_lint": {
              "type": "string"
            },
            "deployment_snapshot": {
              "type": "string"
            }
          },
          "required": [
            "bicep_diagnostics",
            "bicep_build",
            "bicep_lint",
            "deployment_snapshot"
          ]
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "validation_status",
        "check_summary",
        "checks",
        "blockers",
        "validated_files",
        "inputs_used",
        "rule_set_version",
        "tool_results",
        "recommendations"
      ]
    }
  },
  "required": [
    "protocol_version",
    "artifact_type",
    "run_id",
    "generated_by",
    "generated_at",
    "data"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "data": {
            "properties": {
              "validation_status": {
                "const": "PASS"
              }
            },
            "required": [
              "validation_status"
            ]
          }
        },
        "required": [
          "data"
        ]
      },
      "then": {
        "properties": {
          "data": {
            "properties": {
              "blockers": {
                "maxItems": 0
              }
            }
          }
        }
      }
    }
  ]
}
