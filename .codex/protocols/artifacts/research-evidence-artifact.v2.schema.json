{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research-evidence-artifact.v2.schema.json",
  "title": "Research Evidence Artifact v2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocol_version": {
      "const": "workflow.v2"
    },
    "artifact_type": {
      "const": "research.evidence.v2"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[a-z0-9]+(?:-[a-z0-9]+)*_(dev|test|qa|prod)_[a-z0-9]{4}$"
    },
    "generated_by": {
      "const": "research"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence_summary": {
          "type": "string",
          "minLength": 1
        },
        "requirement_mapping": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "requirement_id": {
                "type": "string",
                "minLength": 1
              },
              "finding": {
                "type": "string",
                "minLength": 1
              },
              "guidance": {
                "type": "string",
                "minLength": 1
              },
              "source_url": {
                "type": "string",
                "format": "uri"
              },
              "source_title": {
                "type": "string",
                "minLength": 1
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              }
            },
            "required": [
              "requirement_id",
              "finding",
              "guidance",
              "source_url",
              "source_title",
              "confidence"
            ]
          }
        },
        "conflicts_or_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "implementation_implications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "citations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "service_confirmation_requests": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$"
                  },
                  "header": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 12
                  },
                  "question": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 160
                  },
                  "request_mode": {
                    "const": "selection"
                  },
                  "recommended_option_id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$"
                  },
                  "options": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 3,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "id": {
                          "type": "string",
                          "pattern": "^[a-z][a-z0-9_]*$"
                        },
                        "label": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 80
                        },
                        "description": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 180
                        }
                      },
                      "required": [
                        "id",
                        "label",
                        "description"
                      ]
                    }
                  }
                },
                "required": [
                  "id",
                  "header",
                  "question",
                  "request_mode",
                  "recommended_option_id",
                  "options"
                ]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$"
                  },
                  "header": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 12
                  },
                  "question": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 160
                  },
                  "request_mode": {
                    "const": "forced_confirmation"
                  },
                  "sole_option": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_]*$"
                      },
                      "label": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 80
                      },
                      "description": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 180
                      }
                    },
                    "required": [
                      "id",
                      "label",
                      "description"
                    ]
                  },
                  "sole_option_reason": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 180
                  }
                },
                "required": [
                  "id",
                  "header",
                  "question",
                  "request_mode",
                  "sole_option",
                  "sole_option_reason"
                ]
              }
            ]
          }
        }
      },
      "required": [
        "evidence_summary",
        "requirement_mapping",
        "conflicts_or_gaps",
        "implementation_implications",
        "citations",
        "service_confirmation_requests"
      ]
    }
  },
  "required": [
    "protocol_version",
    "artifact_type",
    "run_id",
    "generated_by",
    "generated_at",
    "data"
  ]
}
